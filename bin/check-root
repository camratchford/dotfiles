#!/bin/bash

HELP=$(cat <<EOF
Checks if user is root, exits with message if not.

Usage:
    check-root [FLAGS]

FLAGS:
    --help,-h  Print this message and exits
EOF
)

if [[ $1 == "-h" || $1 == "--help" ]]; then
    echo "$HELP"
    exit
fi

if [[ $EUID -ne 0 ]]; then
  echo "This script must be run as root" 1>&2
  exit 100
fi
