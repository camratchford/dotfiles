# https://github.com/dustinkirkland/byobu/blob/10de76532599ad2bb2365cb8a0ea2d9d4e21d86b/usr/bin/col1
if [ $# -gt 0 ]; then
    ifs='-F'"$1"
    shift || true
else
    ifs="-F "
fi
b=$(basename $0)
awk "$ifs" '{print $'${b#col}'}' "$@"
