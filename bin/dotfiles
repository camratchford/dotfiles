function execute-sub-command {
  readarray LOCAL_FUNCS <<< "$(grep -Po "$FUNC_FIND_REGEX" "${BASH_SOURCE[0]}")"
  local max_len=0
  local -a func_names func_lines
  while IFS=':' read -r lineno name; do
    func_names+=("${name}")
    func_lines+=("${lineno}")
    [[ ${#name} -gt $max_len ]] && max_len=${#name}
  done < <(grep -n '^[[:space:]]*function[[:space:]]\+[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*{' "${file}" \
    | sed 's/^\([0-9]*\):[[:space:]]*function[[:space:]]\+\([a-zA-Z_][a-zA-Z0-9_]*\)[[:space:]]*{.*$/\1:\2/')

  unset -v "${LOCAL_FUNCS[@]}"
}


unset -v THIS_FILE FUNC_FIND_REGEX
