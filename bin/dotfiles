#!/bin/bash

FUNC_FIND_REGEX='^[[:space:]]*\(function[[:space:]]\+\)\?[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*()'
FUNC_FIND_REGEX='(?<=^function )(.*)(?=\(\)| {)'

function help {
  local FILE_FOR_HELP
  FILE_FOR_HELP="${1:-${BASH_SOURCE[0]}}}"

  local help_match=()

  readarray help_match <<< "$(grep -A1 --no-group-separator "^function" "$FILE_FOR_HELP")"

  printf  "\n$(tput setaf 155)%s:$(tput sgr0)\n" "$(basename -s '.sh' "$FILE_FOR_HELP")"
  for i in $(seq 1 2 ${#help_match[@]}); do
    func_name=$(echo "${help_match[i-1]}" | grep -Po "(?<=^function )(.*)(?=\(\)| {)")
    help_msg=$(echo "${help_match[i]}"  | grep -Po "(?<=\# )(.*)" )

    printf "    $(tput setaf 203)%s\n      $(tput sgr0)%s\n\n" "$func_name" "$help_msg"
  done
}

functions_list() {
  local file="${1:-${BASH_SOURCE[0]}}"

  if [[ ! -r "${file}" ]]; then
    echo "functions_list: cannot read file: ${file}" >&2
    return 1
  fi

  # Find all function definition line numbers and names
  local max_len=0
  local -a func_names func_lines

  while IFS=':' read -r lineno name; do
    func_names+=("${name}")
    func_lines+=("${lineno}")
    [[ ${#name} -gt $max_len ]] && max_len=${#name}
  done < <(grep -n '^[[:space:]]*\(function[[:space:]]\+\)\?[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*()' "${file}" \
    | sed 's/^\([0-9]*\):[[:space:]]*\(function[[:space:]]*\)\?\([a-zA-Z_][a-zA-Z0-9_]*\)[[:space:]]*(.*$/\1:\3/')

  if [[ ${#func_names[@]} -eq 0 ]]; then
    echo "(no functions found in ${file})"
    return 0
  fi

  # For each function, grab only the single comment line immediately above it
  local i
  for i in "${!func_names[@]}"; do
    local name="${func_names[$i]}"
    local above=$(( func_lines[$i] - 1 ))
    local summary=""

    if [[ ${above} -gt 0 ]]; then
      local prev_line
      prev_line=$(sed -n "${above}p" "${file}")
      if [[ "${prev_line}" =~ ^[[:space:]]*#(.*) ]]; then
        summary="${BASH_REMATCH[1]# }"
      fi
    fi

    printf "  %-*s  %s\n" "${max_len}" "${name}" "${summary}"
  done
}

